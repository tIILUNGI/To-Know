# TO KNOW - Environment Variables
# Copy this file to .env and fill in the values

# JWT Secret (generate a strong secret for production)
JWT_SECRET=toknow-prod-secret-change-this

# Database (Vercel Postgres)
# When deployed to Vercel, the DATABASE_URL is automatically provided if you add a Postgres integration
DATABASE_URL=postgresql://user:password@host:port/database

# Node environment
NODE_ENV=production
